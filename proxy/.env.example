# Scorer service
SCORER_URL=http://localhost:8403

# OpenRouter API Key (required)
# OPENROUTER_API_KEY=sk-or-v1-...

# Server Configuration
# CLAW_PROXY_PORT=8402
# CLAW_PROXY_HOST=0.0.0.0

# Ollama Configuration
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_ENABLED=true

# Auto Profile Models
# CLAW_PROXY_AUTO_SIMPLE=google/gemini-flash-1.5
# CLAW_PROXY_AUTO_MEDIUM=anthropic/claude-3-5-haiku-20241022
# CLAW_PROXY_AUTO_COMPLEX=anthropic/claude-3-5-sonnet-20241022
# CLAW_PROXY_AUTO_REASONING=anthropic/claude-3-opus-20240229

# Eco Profile Models
# CLAW_PROXY_ECO_SIMPLE=amazon/nova-lite-v1
# CLAW_PROXY_ECO_MEDIUM=google/gemini-flash-1.5
# CLAW_PROXY_ECO_COMPLEX=anthropic/claude-3-5-haiku-20241022
# CLAW_PROXY_ECO_REASONING=anthropic/claude-3-5-sonnet-20241022

# Premium Profile Models
# CLAW_PROXY_PREMIUM_SIMPLE=anthropic/claude-3-5-haiku-20241022
# CLAW_PROXY_PREMIUM_MEDIUM=anthropic/claude-3-5-sonnet-20241022
# CLAW_PROXY_PREMIUM_COMPLEX=anthropic/claude-3-opus-20240229
# CLAW_PROXY_PREMIUM_REASONING=anthropic/claude-3-opus-20240229

# Session Configuration
# CLAW_PROXY_SESSION_TTL=120
# CLAW_PROXY_NEVER_DOWNGRADE=true
# CLAW_PROXY_THREE_STRIKE_ESCALATION=true

# Cache Configuration
# CLAW_PROXY_CACHE_ENABLED=true
# CLAW_PROXY_CACHE_MAX_ENTRIES=200
# CLAW_PROXY_CACHE_TTL=600

# Compression Configuration
# CLAW_PROXY_COMPRESSION_ENABLED=true

# Logging Configuration
# CLAW_PROXY_LOG_DIR=~/.claw-proxy/logs
# CLAW_PROXY_LOG_ENABLED=true

# Routing Configuration
# CLAW_PROXY_DEFAULT_TIER=MEDIUM
# CLAW_PROXY_CONFIDENCE_THRESHOLD=0.3
